{
  "name": "workontap-admin",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "preinstall": "cross-env PUPPETEER_SKIP_DOWNLOAD=true",
    "postinstall": "node scripts/patch-ts-interface.cjs",
    "clean": "rimraf node_modules package-lock.json && rimraf %USERPROFILE%\\.cache\\puppeteer",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:init": "node --experimental-modules database/schema.js",
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "test:report": "npx playwright show-report"
  },
  "type": "module",
  "dependencies": {
    "@react-pdf/renderer": "^4.3.2",
    "@stripe/react-stripe-js": "^5.6.0",
    "@stripe/stripe-js": "^8.8.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "jose": "^6.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.563.0",
    "mime": "^4.1.0",
    "multer": "^2.0.2",
    "mysql2": "^3.18.0",
    "next": "^15.2.0",
    "nodemailer": "^8.0.1",
    "playwright": "^1.58.2",
    "preinstall": "^0.0.1-security",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.6.0",
    "stripe": "^20.4.0",
    "sweetalert2": "^11.26.21",
    "toast": "^0.5.4"
  },
  "optionalDependencies": {
    "puppeteer": "^24.37.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.1.3",
    "patch-package": "^8.0.0",
    "postcss": "^8.4.49",
    "rimraf": "^5.0.1",
    "tailwindcss": "^3.4.17"
